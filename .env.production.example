# Production database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Auth
AUTH_SECRET=replace-with-a-strong-random-secret

# Public application URL
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Default business widget shown on the homepage
DEFAULT_BUSINESS_WIDGET_KEY=your-production-widget-key

# Email notifications
RESEND_API_KEY=re_xxxxxxxx
OWNER_NOTIFICATION_EMAIL=owner@example.com
RESEND_FROM_EMAIL=SiteAgentAI <notifications@example.com>

# AI summaries
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Stripe billing
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_ENFORCE_SUBSCRIPTIONS=true
