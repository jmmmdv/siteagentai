# Database (required for live lead capture)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Set to "false" only for local Postgres without SSL
# DATABASE_SSL=false

# Auth (required for owner login)
AUTH_SECRET=generate-a-long-random-string

# Default widget on marketing homepage (from seed-owner output)
DEFAULT_BUSINESS_WIDGET_KEY=your-widget-key-here

# Public app URL for embed codes (production)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email notifications (optional — leads still save without these)
RESEND_API_KEY=re_xxxxxxxx
OWNER_NOTIFICATION_EMAIL=you@yourbusiness.com
RESEND_FROM_EMAIL=SiteAgentAI <notifications@yourdomain.com>

# AI summaries (optional — falls back to rule-based summaries without this)
OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# Stripe billing (optional — mailto pilot CTA when not configured)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# Set to "false" to allow lead capture without an active subscription (demo mode)
# STRIPE_ENFORCE_SUBSCRIPTIONS=false

# Seed script only (npm run seed:owner)
# ADMIN_EMAIL=owner@yourbusiness.com
# ADMIN_PASSWORD=choose-a-strong-password
# ADMIN_NAME=Your Name
# BUSINESS_NAME=Your Business Name
# BUSINESS_SLUG=your-business
# BUSINESS_NOTIFICATION_EMAIL=owner@yourbusiness.com
